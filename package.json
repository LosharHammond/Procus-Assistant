    "mongodb": "^6.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "body-parser": "^1.20.2",
    "jest": "^29.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0"
